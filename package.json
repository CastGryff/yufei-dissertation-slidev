{
  "name": "yufei-dissertation-slidev",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "slidev --port 3030",
    "build": "slidev build",
    "export": "slidev export --output dissertation-defense.pdf --timeout 180000 --wait-until networkidle --wait 2500",
    "export:clicks": "slidev export --with-clicks --output dissertation-defense-clicks.pdf --timeout 180000 --wait-until networkidle --wait 2500"
  },
  "dependencies": {
    "@slidev/cli": "52.14.2",
    "@slidev/theme-default": "0.25.0",
    "slidev-component-progress": "^1.1.0",
    "vue": "3.5.33"
  },
  "devDependencies": {
    "playwright-chromium": "1.59.1"
  }
}
